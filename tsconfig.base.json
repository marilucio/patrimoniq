{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@patrimoniq/domain": ["packages/domain/src/index.ts"],
      "@patrimoniq/domain/*": ["packages/domain/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@api/*": ["apps/api/src/*"]
    }
  }
}
