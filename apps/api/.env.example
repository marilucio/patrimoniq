SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_VERIFY_CONNECTION=true
ENABLE_SMTP_SELF_TEST=true
COOKIE_SAME_SITE=lax
MONITORING_PROVIDER=none
MONITORING_WEBHOOK_URL=
